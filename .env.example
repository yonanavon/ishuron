DATABASE_URL="postgresql://user:password@localhost:5432/ishuron?schema=public"
JWT_SECRET="your-secret-key-change-me"
PORT=3000
NODE_ENV=development

# Multi-tenant config
# Parent domain for tenant subdomains. In production: e.g. ishuron.com
ROOT_DOMAIN=ishuron.com
# Reserved subdomain that serves the super-admin UI/API. e.g. admin.ishuron.com
SUPER_ADMIN_SLUG=admin
# In dev, if the URL has no subdomain, which school slug to fall back to.
DEV_DEFAULT_SLUG=default
# Optional: set to override the seeded super-admin password.
SUPER_ADMIN_PASSWORD=
